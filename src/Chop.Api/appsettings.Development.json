{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5432;Database=chop2g;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "Chop2G",
    "Audience": "Chop2G.Api",
    "SigningKey": "dev-only-signing-key-at-least-32chars",
    "AccessTokenTtlMinutes": 15,
    "RefreshTokenTtlDays": 30
  },
  "Auth": {
    "PasswordHashing": {
      "Iterations": 120000,
      "SaltSizeBytes": 16,
      "KeySizeBytes": 32
    }
  },
  "Notifications": {
    "Outbox": {
      "PollIntervalMs": 250,
      "BatchSize": 50,
      "MaxAttempts": 5
    }
  },
  "Alerts": {
    "Sla": {
      "PollIntervalMs": 1000,
      "NoAcceptStuckSeconds": 60,
      "GuardOfflineSeconds": 60,
      "StuckInStatusSeconds": 180
    }
  },
  "Platform": {
    "Reliability": {
      "OutboxPollIntervalMs": 250,
      "OutboxBatchSize": 100,
      "OutboxMaxAttempts": 5,
      "OutboxRetryBaseSeconds": 1,
      "OutboxRetryMaxSeconds": 10,
      "OutboxLagUnhealthyThresholdSeconds": 30,
      "OutboxFailedLookbackMinutes": 15,
      "OutboxFailedUnhealthyThresholdCount": 50,
      "OutboxRetryWarningAttemptThreshold": 3,
      "OutboxRetentionDays": 7,
      "AuditRetentionDays": 90
    }
  },
  "Realtime": {
    "Bus": {
      "Enabled": false,
      "HostName": "127.0.0.1",
      "Port": 5672,
      "VirtualHost": "/",
      "UserName": "guest",
      "Password": "guest",
      "Exchange": "chop.realtime",
      "ExchangeType": "topic",
      "Queue": "chop.realtime.signalr",
      "RoutingKeyPattern": "realtime.#",
      "Durable": true
    }
  },
  "Secrets": {
    "KeyPerFilePath": ""
  },
  "SecurityPoints": {
    "AddressNormalization": {
      "EnableGeocoding": false,
      "YandexGeocoderApiKey": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
