{
  "Jwt": {
    "Issuer": "Chop2G",
    "Audience": "Chop2G.Api",
    "SigningKey": "replace-in-production-with-secret-key-32+",
    "AccessTokenTtlMinutes": 15,
    "RefreshTokenTtlDays": 30
  },
  "Notifications": {
    "Outbox": {
      "PollIntervalMs": 500,
      "BatchSize": 50,
      "MaxAttempts": 5
    }
  },
  "Alerts": {
    "Sla": {
      "PollIntervalMs": 5000,
      "NoAcceptStuckSeconds": 120,
      "GuardOfflineSeconds": 120,
      "StuckInStatusSeconds": 300
    }
  },
  "Platform": {
    "Reliability": {
      "OutboxPollIntervalMs": 500,
      "OutboxBatchSize": 100,
      "OutboxMaxAttempts": 5,
      "OutboxRetryBaseSeconds": 2,
      "OutboxRetryMaxSeconds": 60,
      "OutboxLagUnhealthyThresholdSeconds": 120,
      "OutboxRetentionDays": 7,
      "AuditRetentionDays": 90
    }
  },
  "SecurityPoints": {
    "AddressNormalization": {
      "EnableGeocoding": false,
      "YandexGeocoderApiKey": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
