@inject Chop.Web.Auth.WebAuthSession Session
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@implements IDisposable

<nav class="space-y-1">
    @if (!Session.IsAuthenticated)
    {
        <NavLink
            class="block rounded-md px-3 py-2 text-sm text-ink-700 hover:bg-ink-50 hover:text-ink-900"
            ActiveClass="bg-ink-100 text-ink-900"
            href="login">
            Вход
        </NavLink>
    }
    else
    {
        @if (Session.IsInAnyRole(Chop.Web.Auth.RoleConstants.OpsRoles))
        {
            <div class="px-3 pt-2 text-xs font-semibold uppercase tracking-wide text-white/60">Оператор</div>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="operator/dashboard">Дашборд</NavLink>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="operator/incidents">Инциденты</NavLink>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="operator/forces">Локация групп</NavLink>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="operator/points">Точки</NavLink>
        }

        @if (Session.IsInAnyRole(Chop.Web.Auth.RoleConstants.HrRoles))
        {
            <div class="px-3 pt-4 text-xs font-semibold uppercase tracking-wide text-white/60">Кадры</div>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="hr/guards">Охранники</NavLink>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="hr/groups">Группы</NavLink>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="hr/shifts">Смены</NavLink>
        }

        @if (Session.IsInAnyRole(Chop.Web.Auth.RoleConstants.AdminRoles))
        {
            <div class="px-3 pt-4 text-xs font-semibold uppercase tracking-wide text-white/60">Администратор</div>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="admin/clients">Клиенты</NavLink>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="admin/payments/import">Импорт платежей</NavLink>
        }

        @if (Session.IsInAnyRole(Chop.Web.Auth.RoleConstants.ManagerRoles) && !Session.IsInAnyRole(Chop.Web.Auth.RoleConstants.AdminRoles))
        {
            <div class="px-3 pt-4 text-xs font-semibold uppercase tracking-wide text-white/60">Менеджер</div>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="manager/clients">Сводка по клиентам</NavLink>
        }

        @if (Session.IsInAnyRole(Chop.Web.Auth.RoleConstants.AccountantRoles) && !Session.IsInAnyRole(Chop.Web.Auth.RoleConstants.AdminRoles))
        {
            <div class="px-3 pt-4 text-xs font-semibold uppercase tracking-wide text-white/60">Бухгалтерия</div>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="accountant/payments/import">Импорт платежей</NavLink>
        }

        @if (Session.IsInAnyRole(Chop.Web.Auth.RoleConstants.SuperAdminOnlyRoles))
        {
            <div class="px-3 pt-4 text-xs font-semibold uppercase tracking-wide text-white/60">Суперадмин</div>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="superadmin/settings">Системные настройки</NavLink>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="superadmin/users">Пользователи</NavLink>
            <NavLink class="block rounded-md px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white" ActiveClass="bg-white/10 text-white" href="superadmin/audit">Системный аудит</NavLink>
        }

        <div class="pt-4">
            <button type="button" class="tw-btn-outline-dark w-full" @onclick="LogoutAsync">Выход</button>
        </div>
    }
</nav>

@code {
    protected override void OnInitialized()
    {
        Session.Changed += OnSessionChanged;
    }

    private void OnSessionChanged() => InvokeAsync(StateHasChanged);

    private async Task LogoutAsync()
    {
        await JS.InvokeVoidAsync("chopAuth.clearSession");
        Session.SignOut();
        NavigationManager.NavigateTo("/login", replace: true);
    }

    public void Dispose()
    {
        Session.Changed -= OnSessionChanged;
    }
}
