<div class="tw-card mb-4">
    <div class="tw-card-body">
        <div class="@GridClass">
            @ChildContent
            <div class="@ActionColumnClass">
                @if (ActionContent is null)
                {
                    <button type="button" class="tw-btn-outline w-full" @onclick="OnRefresh" disabled="@Disabled">@RefreshText</button>
                }
                else
                {
                    @ActionContent
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? ActionContent { get; set; }

    [Parameter]
    public EventCallback OnRefresh { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string RefreshText { get; set; } = "Обновить";

    [Parameter]
    public string GridClass { get; set; } = "grid gap-3 md:grid-cols-12";

    [Parameter]
    public string ActionColumnClass { get; set; } = "md:col-span-2 flex items-end";
}
