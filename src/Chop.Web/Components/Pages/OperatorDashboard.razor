    private async void OnGuardLocationUpdated(Chop.Shared.Contracts.Realtime.GuardLocationUpdatedEvent payload)
    {
        if (_selectedIncidentId is null || payload.IncidentId is null)
        {
            return;
        }

        if (payload.IncidentId.Value != _selectedIncidentId.Value)
        {
            return;
        }

        _guardLocations[payload.GuardUserId] = payload.Location;
        await UpdateMapAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CreateDispatchGroupAsync(char group)
    {
        if (_selectedDetails is null)
        {
            return;
        }

        var selectedGroup = group == 'A' ? _dispatchAGroup : _dispatchBGroup;
        var anotherSelectedGroup = group == 'A' ? _dispatchBGroup : _dispatchAGroup;
        if (string.IsNullOrWhiteSpace(selectedGroup))
        {
            _error = $"Не выбрана группа {group}.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(anotherSelectedGroup) && string.Equals(selectedGroup, anotherSelectedGroup, StringComparison.OrdinalIgnoreCase))
        {
            _error = "Для группы A и группы B нужны разные группы.";
            return;
        }

        var selected = _onDutyGroups.FirstOrDefault(x => string.Equals(x.Name, selectedGroup, StringComparison.OrdinalIgnoreCase));
        if (selected is null)
        {
            _error = $"Группа {selectedGroup} не найдена среди активных смен.";
            return;
        }

        if (selected.GuardUserIds.Count == 0)
        {
            _error = $"В выбранной группе нет охранников на смене для группы {group}.";
            return;
        }

        _busyDispatch = true;
        _error = null;
        try
        {
            var dto = new CreateDispatchDto
            {
                Method = _dispatchMethod,
                Comment = BuildDispatchComment(group, selected.Name),
                Recipients = selected.GuardUserIds.Select(x => new DispatchRecipientInputDto
                {
                    Type = "GUARD",
                    Id = x,
                }).ToArray(),
            };

            await ApiClient.CreateDispatchAsync(_selectedDetails.Id, dto, CancellationToken.None);
            await LoadSelectedAsync(_selectedDetails.Id);
        }
        catch (Exception ex)
        {
            if (Chop.Web.Auth.AuthErrorRedirector.TryRedirect(ex, Session, NavigationManager))
            {
                return;
            }

            _error = Chop.Web.Auth.UiErrorMapper.ToUserMessage(ex);
        }
        finally
        {
            _busyDispatch = false;
        }
    }

    private async Task ReloadOnDutyGroupsAsync()
    {
        var shifts = await BackofficeClient.GetActiveShiftsAsync(CancellationToken.None);
        _onDutyGuardNames.Clear();
        foreach (var shift in shifts.Where(x => !string.IsNullOrWhiteSpace(x.GuardUserId)))
        {
            _onDutyGuardNames[shift.GuardUserId] = string.IsNullOrWhiteSpace(shift.GuardFullName)
                ? shift.GuardUserId
                : shift.GuardFullName;
        }

        _onDutyGroups = shifts
            .Where(x => !string.IsNullOrWhiteSpace(x.GuardGroupName))
            .GroupBy(x => x.GuardGroupName!.Trim(), StringComparer.OrdinalIgnoreCase)
            .Select(group => new OnDutyGroupOption(
                group.Key,
                $"{group.Key} ({group.Select(x => x.GuardUserId).Distinct(StringComparer.OrdinalIgnoreCase).Count()})",
                group.Select(x => x.GuardUserId).Distinct(StringComparer.OrdinalIgnoreCase).ToArray(),
                group
                    .Select(x => new OnDutyGuardOption(
                        x.GuardUserId,
                        !string.IsNullOrWhiteSpace(x.GuardFullName) ? x.GuardFullName : x.GuardUserId,
                        x.SecurityPointLabel))
                    .OrderBy(x => x.DisplayName, StringComparer.OrdinalIgnoreCase)
                    .ToArray()))
            .Where(x => x.GuardUserIds.Count > 0)
            .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (_dispatchAGroup is not null && _onDutyGroups.All(x => !string.Equals(x.Name, _dispatchAGroup, StringComparison.OrdinalIgnoreCase)))
        {
            _dispatchAGroup = null;
        }

        if (_dispatchBGroup is not null && _onDutyGroups.All(x => !string.Equals(x.Name, _dispatchBGroup, StringComparison.OrdinalIgnoreCase)))
        {
            _dispatchBGroup = null;
        }
    }

