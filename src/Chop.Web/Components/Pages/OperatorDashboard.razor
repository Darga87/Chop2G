    private string BuildDispatchComment(char slot, string groupName)
    {
        var target = slot == 'A' ? "ALERT" : "HOME";
        var parts = new List<string>(capacity: 4);
        if (!string.IsNullOrWhiteSpace(_dispatchComment))
        {
            parts.Add(_dispatchComment.Trim());
        }

        parts.Add($"[slot:{char.ToUpperInvariant(slot)}]");
        parts.Add($"[target:{target}]");
        parts.Add($"[group:{groupName}]");
        return string.Join(" ", parts);
    }

    private static string ExtractDispatchTag(string? comment, string tag)
    {
        if (string.IsNullOrWhiteSpace(comment))
        {
            return string.Empty;
        }

        var marker = $"[{tag}:";
        var start = comment.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
        if (start < 0)
        {
            return string.Empty;
        }

        start += marker.Length;
        var end = comment.IndexOf(']', start);
        if (end <= start)
        {
            return string.Empty;
        }

        return comment[start..end].Trim();
    }

    private static string GetDispatchGroupName(DispatchDto dispatch)
    {
        var group = ExtractDispatchTag(dispatch.Comment, "group");
        return string.IsNullOrWhiteSpace(group) ? "Не указана" : group;
    }

    private static string GetDispatchTargetLabel(DispatchDto dispatch)
    {
        var target = ExtractDispatchTag(dispatch.Comment, "target");
        if (string.IsNullOrWhiteSpace(target))
        {
            var slot = ExtractDispatchTag(dispatch.Comment, "slot");
            target = string.Equals(slot, "A", StringComparison.OrdinalIgnoreCase) ? "ALERT"
                : string.Equals(slot, "B", StringComparison.OrdinalIgnoreCase) ? "HOME"
                : string.Empty;
        }

        return target.ToUpperInvariant() switch
        {
            "ALERT" => "Точка тревоги",
            "HOME" => "Точка дома",
            _ => "Не указано",
        };
    }

    private string GetGuardDisplayName(string guardUserId)
    {
        if (_onDutyGuardNames.TryGetValue(guardUserId, out var fullName) && !string.IsNullOrWhiteSpace(fullName))
        {
            return $"{fullName} ({guardUserId})";
        }

        return guardUserId;
    }

