    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            await ReloadOnDutyGroupsAsync();
            var page = await ApiClient.GetIncidentsAsync(_statusFilter, null, null, 1, 50, CancellationToken.None);
            _items.Clear();
            _items.AddRange(page.Items);
            await RealtimeClient.SyncIncidentSubscriptionsAsync(_items.Select(x => x.Id), CancellationToken.None);

            if (_selectedIncidentId.HasValue && _items.All(x => x.Id != _selectedIncidentId.Value))
            {
                _selectedIncidentId = null;
                _selectedDetails = null;
            }

            if (_selectedIncidentId.HasValue)
            {
                await LoadSelectedAsync(_selectedIncidentId.Value);
            }

            await UpdateMapAsync();
        }
        catch (Exception ex)
        {
            if (Chop.Web.Auth.AuthErrorRedirector.TryRedirect(ex, Session, NavigationManager))
            {
                return;
            }

            _error = Chop.Web.Auth.UiErrorMapper.ToUserMessage(ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SelectIncidentAsync(Guid id)
    {
        _selectedIncidentId = id;
        _guardLocations.Clear();
        await RealtimeClient.SubscribeIncidentAsync(id, CancellationToken.None);
        await LoadSelectedAsync(id);
    }

    private async Task LoadSelectedAsync(Guid id)
    {
        _error = null;
        try
        {
            _selectedDetails = await ApiClient.GetIncidentByIdAsync(id, CancellationToken.None);
            _homeAddress = _selectedDetails?.Addresses
                .OrderByDescending(x => x.IsPrimary)
                .ThenBy(x => x.Label)
                .FirstOrDefault();
            var dispatches = _selectedDetails?.Dispatches
                .OrderByDescending(x => x.CreatedAt)
                .ToArray() ?? [];
            _dispatchA = dispatches.FirstOrDefault(x => string.Equals(ExtractDispatchTag(x.Comment, "slot"), "A", StringComparison.OrdinalIgnoreCase));
            _dispatchB = dispatches.FirstOrDefault(x => string.Equals(ExtractDispatchTag(x.Comment, "slot"), "B", StringComparison.OrdinalIgnoreCase));

            if (_dispatchA is null)
            {
                _dispatchA = dispatches.ElementAtOrDefault(0);
            }

            if (_dispatchB is null)
            {
                _dispatchB = dispatches.FirstOrDefault(x => !ReferenceEquals(x, _dispatchA));
            }

            await ReloadAlertsAsync();
            await UpdateMapAsync();
        }
        catch (Exception ex)
        {
            if (Chop.Web.Auth.AuthErrorRedirector.TryRedirect(ex, Session, NavigationManager))
            {
                return;
            }

            _error = Chop.Web.Auth.UiErrorMapper.ToUserMessage(ex);
        }
    }

    private async Task ReloadAlertsAsync()
    {
        _alerts.Clear();
        if (_selectedDetails is null)
        {
            return;
        }

        try
        {
            var serverAlerts = await ApiClient.GetIncidentAlertsAsync(_selectedDetails.Id, includeResolved: true, CancellationToken.None);
            _alerts.AddRange(serverAlerts);
        }
        catch (Exception ex)
        {
            if (Chop.Web.Auth.AuthErrorRedirector.TryRedirect(ex, Session, NavigationManager))
            {
                return;
            }

            _error = $"Не удалось загрузить алерты: {ex.Message}";
        }
    }

    private async void OnIncidentCreated(Chop.Shared.Contracts.Realtime.IncidentCreatedEvent payload)
    {
        var mapped = new IncidentListItemDto
        {
            Id = payload.Incident.Id,
            Status = payload.Incident.Status,
            CreatedAt = payload.Incident.CreatedAt,
            AddressSnapshot = payload.Incident.AddressSnapshot,
            ClientSummary = payload.Incident.ClientSummary,
            LastUpdatedAt = payload.Incident.LastUpdatedAt,
        };

        _items.RemoveAll(x => x.Id == mapped.Id);
        _items.Insert(0, mapped);
        await RealtimeClient.SubscribeIncidentAsync(mapped.Id, CancellationToken.None);
        await InvokeAsync(StateHasChanged);
    }

    private async void OnIncidentStatusChanged(Chop.Shared.Contracts.Realtime.IncidentStatusChangedEvent payload)
    {
        var existing = _items.FirstOrDefault(x => x.Id == payload.IncidentId);
        if (existing is not null)
        {
            existing.Status = payload.ToStatus;
            existing.LastUpdatedAt = payload.Incident.LastUpdatedAt;
            existing.AddressSnapshot = payload.Incident.AddressSnapshot;
            existing.ClientSummary = payload.Incident.ClientSummary;
        }
        else
        {
            _items.Insert(0, new IncidentListItemDto
            {
                Id = payload.Incident.Id,
                Status = payload.Incident.Status,
                CreatedAt = payload.Incident.CreatedAt,
                AddressSnapshot = payload.Incident.AddressSnapshot,
                ClientSummary = payload.Incident.ClientSummary,
                LastUpdatedAt = payload.Incident.LastUpdatedAt,
            });
        }

        if (_selectedIncidentId == payload.IncidentId)
        {
            await LoadSelectedAsync(payload.IncidentId);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async void OnDispatchCreated(Chop.Shared.Contracts.Realtime.DispatchCreatedEvent payload)
    {
        if (_selectedIncidentId == payload.IncidentId)
        {
            await LoadSelectedAsync(payload.IncidentId);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void OnDispatchAccepted(Chop.Shared.Contracts.Realtime.DispatchAcceptedEvent payload)
