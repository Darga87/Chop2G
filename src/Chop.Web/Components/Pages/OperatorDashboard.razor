                    balloon = "Застревание диспетчеризации: никто не принял в SLA-окно.",
                });
            }

            var hasNoPingAlert = _alerts.Any(x => x.RuleCode == "INCIDENT_GUARD_NO_PING");
            if (hasNoPingAlert && _selectedDetails?.Location is not null)
            {
                markers.Add(new
                {
                    id = "alert:no-ping",
                    lat = _selectedDetails.Location.Lat,
                    lon = _selectedDetails.Location.Lon,
                    preset = "islands#violetIcon",
                    hint = "НЕТ ПИНГА",
                    balloon = "Охранник принял задачу, но гео-пинги еще не поступали.",
                });
            }

            var hasGuardOfflineAlert = _alerts.Any(x => x.RuleCode == "INCIDENT_GUARD_OFFLINE");
            if (hasGuardOfflineAlert && _selectedDetails?.Location is not null)
            {
                markers.Add(new
                {
                    id = "alert:guard-offline",
                    lat = _selectedDetails.Location.Lat,
                    lon = _selectedDetails.Location.Lon,
                    preset = "islands#blackIcon",
                    hint = "ОХРАННИК ОФФЛАЙН",
                    balloon = "Охранник оффлайн: нет гео-пинга в SLA-окне.",
                });
            }

            var hasStuckInStatusAlert = _alerts.Any(x => x.RuleCode == "INCIDENT_STUCK_IN_STATUS");
            if (hasStuckInStatusAlert && _selectedDetails?.Location is not null)
            {
                markers.Add(new
                {
                    id = "alert:stuck-in-status",
                    lat = _selectedDetails.Location.Lat,
                    lon = _selectedDetails.Location.Lon,
                    preset = "islands#grayIcon",
                    hint = "ЗАСТРЯЛ В СТАТУСЕ",
                    balloon = "Инцидент застрял в EN_ROUTE/ON_SCENE дольше SLA.",
                });
            }

            var hasPointConflictAlert = _alerts.Any(x => x.RuleCode == "INCIDENT_POINT_CONFLICT");
            if (hasPointConflictAlert && _selectedDetails?.Location is not null)
            {
                markers.Add(new
                {
                    id = "alert:point-conflict",
                    lat = _selectedDetails.Location.Lat,
                    lon = _selectedDetails.Location.Lon,
                    preset = "islands#orangeIcon",
                    hint = "КОНФЛИКТ ТОЧЕК",
                    balloon = "Конфликт точек ТРЕВОГИ и ДОМА (расстояние выше порога).",
                });
            }

            if (_selectedIncidentId is Guid selectedId)
            {
                foreach (var kvp in _guardLocations)
                {
                    var guardUserId = kvp.Key;
                    var loc = kvp.Value;
                    markers.Add(new
                    {
                        id = $"guard:{guardUserId}",
                        lat = loc.Lat,
                        lon = loc.Lon,
                    preset = "islands#greenIcon",
                    hint = $"ОХРАННИК {guardUserId}",
                    balloon = $"ОХРАННИК<br/>{System.Net.WebUtility.HtmlEncode(guardUserId)}<br/>инцидент: {selectedId}",
                    });
                }
            }

            await JS.InvokeVoidAsync("chopMaps.setMarkers", "operatorDashboardMap", markers);
        }
        catch (Exception ex)
        {
            _mapError = $"Ошибка обновления карты: {ex.Message}";
