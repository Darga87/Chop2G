@page "/login"
@rendermode InteractiveServer
@using Chop.Shared.Contracts.Auth
@inject Chop.Web.Incidents.IncidentsApiClient ApiClient
@inject Chop.Web.Auth.WebAuthSession Session
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Environment
@inject ILogger<Login> Logger
@inject IJSRuntime JS

<PageTitle>Вход</PageTitle>

<h1 class="mb-4">Вход в веб-консоль</h1>

<EditForm Model="_model" OnValidSubmit="LoginAsync" FormName="login" Enhance="false" class="tw-card">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="tw-card-body space-y-4">
        @if (Environment.IsDevelopment())
        {
            <div class="tw-alert-info">
                Отладка: login.len=@(_model.Login?.Length ?? 0), password.len=@(_model.Password?.Length ?? 0)
            </div>
        }

        <div>
            <label class="block text-sm font-medium text-ink-700">Логин</label>
            <input
                id="loginInput"
                name="login"
                autocomplete="username"
                class="tw-input mt-1"
                value="@_model.Login"
                @oninput="OnLoginInput" />
        </div>

        <div>
            <label class="block text-sm font-medium text-ink-700">Пароль</label>
            <input
                id="passwordInput"
                name="password"
                autocomplete="current-password"
                class="tw-input mt-1"
                type="password"
                value="@_model.Password"
                @oninput="OnPasswordInput" />
        </div>

        <div class="flex items-center gap-3">
            <button class="tw-btn-primary" type="submit" disabled="@_busy">Войти</button>
            <span class="text-sm text-ink-500">API: <code>http://localhost:5261</code></span>
        </div>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="tw-alert-danger">@_error</div>
        }
        @if (!string.IsNullOrWhiteSpace(_successRoute))
        {
            <div class="tw-alert-success">
                Вход выполнен. Продолжить: <a href="@_successRoute">@_successRoute</a>
            </div>
        }
    </div>
</EditForm>

@code {
    private readonly LoginRequestDto _model = new();
    private bool _busy;
    private string? _error;
    private bool _jsReady;
    private string? _successRoute;

    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated)
        {
            NavigationManager.NavigateTo(Chop.Web.Auth.AuthNavigation.ResolveDefaultRoute(Session), replace: true);
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsReady = true;
        }

        return Task.CompletedTask;
    }

    private void OnLoginInput(ChangeEventArgs args)
    {
        _model.Login = args.Value?.ToString() ?? string.Empty;
    }

    private void OnPasswordInput(ChangeEventArgs args)
    {
        _model.Password = args.Value?.ToString() ?? string.Empty;
    }

    private async Task LoginAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            // Browser autofill can skip input/change events; read actual DOM values as fallback.
            var login = _model.Login;
            var password = _model.Password;
            if (_jsReady && string.IsNullOrWhiteSpace(login))
            {
                login = await JS.InvokeAsync<string?>("chopAuth.getValue", "loginInput") ?? string.Empty;
            }

            if (_jsReady && string.IsNullOrWhiteSpace(password))
            {
                password = await JS.InvokeAsync<string?>("chopAuth.getValue", "passwordInput") ?? string.Empty;
            }

            Logger.LogInformation(
                "Login submit: model.login.len={ModelLoginLen}, model.pw.len={ModelPwLen}, dom.login.len={DomLoginLen}, dom.pw.len={DomPwLen}",
                _model.Login?.Length ?? 0,
                _model.Password?.Length ?? 0,
                login.Length,
                password.Length);

            _model.Login = login;
            _model.Password = password;

            var response = await ApiClient.LoginAsync(_model, CancellationToken.None);
            Session.SignIn(response);
            await JS.InvokeVoidAsync("chopAuth.persistSession", response.AccessToken, response.RefreshToken);
            _successRoute = Chop.Web.Auth.AuthNavigation.ResolveDefaultRoute(Session);
            Logger.LogInformation("Login success, redirecting to {Route}", _successRoute);
            NavigationManager.NavigateTo(_successRoute, replace: true);
        }
        catch (Exception ex)
        {
            _error = Environment.IsDevelopment()
                ? $"Ошибка входа: {ex.Message}"
                : "Ошибка входа. Проверьте логин и пароль.";
        }
        finally
        {
            _busy = false;
        }
    }
}
