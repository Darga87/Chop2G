@page "/Error"
@using System.Diagnostics

<PageTitle>Ошибка</PageTitle>

<h1 class="text-danger">Ошибка.</h1>
<h2 class="text-danger">При обработке запроса произошла ошибка.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>ID запроса:</strong> <code>@RequestId</code>
    </p>
}

<h3>Режим разработки</h3>
<p>
    В окружении <strong>Development</strong> отображается более подробная информация об ошибке.
</p>
<p>
    <strong>Окружение Development не должно быть включено на боевом контуре.</strong>
    Это может привести к раскрытию чувствительной информации об исключениях конечным пользователям.
    Для локальной отладки включите окружение <strong>Development</strong>, задав переменную <strong>ASPNETCORE_ENVIRONMENT</strong> в значение <strong>Development</strong>,
    и перезапустите приложение.
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
