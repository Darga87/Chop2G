@page "/hr/shifts"
@page "/operator/shifts"
@inject BackofficeApiClient Store
@inject WebAuthSession Session
@inject NavigationManager NavigationManager

<PageTitle>Смены охраны (HR)</PageTitle>

<h1 class="mb-4">Смены охраны (HR)</h1>

@if (_loading)
{
    <div class="tw-alert-info">Загрузка...</div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="tw-alert-danger mb-4">@_error</div>
    }

    <div class="tw-card mb-4">
        <div class="tw-card-body">
            <div class="mb-2 text-sm font-semibold text-ink-900">Открыть смену</div>
            <div class="grid gap-3 md:grid-cols-12">
                <div class="md:col-span-4">
                    <label class="block text-sm font-medium text-ink-700">Охранник</label>
                    <select class="tw-select mt-1" @bind="_startGuardUserId">
                        <option value="">Выберите охранника</option>
                        @foreach (var guard in _guards)
                        {
                            var guardUserId = guard.Id.ToString("D");
                            <option value="@guardUserId">@guard.FullName (@guardUserId)</option>
                        }
                    </select>
                </div>
                <div class="md:col-span-4">
                    <label class="block text-sm font-medium text-ink-700">Группа</label>
                    <select class="tw-select mt-1" @bind="_startGroupId">
                        <option value="">Без группы</option>
                        @foreach (var group in _groups)
                        {
                            var groupId = group.Id.ToString("D");
                            <option value="@groupId">@group.Name</option>
                        }
                    </select>
                </div>
                <div class="md:col-span-4">
                    <label class="block text-sm font-medium text-ink-700">Точка</label>
                    <select class="tw-select mt-1" @bind="_startPointId">
                        <option value="">Без точки</option>
                        @foreach (var point in _points)
                        {
                            var pointId = point.Id.ToString("D");
                            <option value="@pointId">@point.Code - @point.Label</option>
                        }
                    </select>
                </div>
                <div class="md:col-span-2 flex items-end">
                    <button class="tw-btn-primary w-full" @onclick="StartShiftAsync" disabled="@_busy">Открыть</button>
                </div>
                <div class="md:col-span-2 flex items-end">
                    <button class="tw-btn-outline w-full" @onclick="ReloadAsync" disabled="@_busy">Обновить</button>
                </div>
            </div>
        </div>
    </div>

    <table class="tw-table">
        <thead>
            <tr>
                <th class="tw-th">Охранник</th>
                <th class="tw-th">Группа</th>
                <th class="tw-th">Точка</th>
                <th class="tw-th">Начало смены</th>
                <th class="tw-th"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var shift in _activeShifts)
            {
                <tr class="odd:bg-white even:bg-ink-50">
                    <td class="tw-td">@shift.GuardFullName</td>
                    <td class="tw-td">@(!string.IsNullOrWhiteSpace(shift.GuardGroupName) ? shift.GuardGroupName : "-")</td>
                    <td class="tw-td">@(!string.IsNullOrWhiteSpace(shift.SecurityPointLabel) ? shift.SecurityPointLabel : "-")</td>
                    <td class="tw-td whitespace-nowrap">@shift.StartedAtUtc.ToLocalTime().ToString("g")</td>
                    <td class="tw-td">
                        <button class="tw-btn-danger" @onclick="() => EndShiftAsync(shift.GuardUserId)" disabled="@_busy">Закрыть смену</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private string? _startGuardUserId;
    private string? _startGroupId;
    private string? _startPointId;
    private IReadOnlyCollection<GuardItemDto> _guards = [];
    private IReadOnlyCollection<GuardGroupItemDto> _groups = [];
    private IReadOnlyCollection<OperatorPointItemDto> _points = [];
    private IReadOnlyCollection<GuardShiftItemDto> _activeShifts = [];

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login", replace: true);
            return;
        }

        if (!Session.IsInAnyRole(RoleConstants.ShiftRoles))
        {
            NavigationManager.NavigateTo("/forbidden", replace: true);
            return;
        }

        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _guards = await Store.GetGuardsAsync(null, "active", false, CancellationToken.None);
            _groups = await Store.GetGuardGroupsAsync(CancellationToken.None);
            _points = await Store.GetPointsAsync(null, "all", false, CancellationToken.None);
            _activeShifts = await Store.GetActiveShiftsAsync(CancellationToken.None);
        }
        catch (Exception ex)
        {
            if (Chop.Web.Auth.AuthErrorRedirector.TryRedirect(ex, Session, NavigationManager))
            {
                return;
            }

            _error = Chop.Web.Auth.UiErrorMapper.ToUserMessage(ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task StartShiftAsync()
    {
        if (_busy)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_startGuardUserId))
        {
            _error = "Выберите охранника.";
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            await Store.StartShiftAsync(new StartGuardShiftRequestDto
            {
                GuardUserId = _startGuardUserId,
                GuardGroupId = Guid.TryParse(_startGroupId, out var groupId) ? groupId : null,
                SecurityPointId = Guid.TryParse(_startPointId, out var pointId) ? pointId : null,
            }, CancellationToken.None);

            await ReloadAsync();
        }
        catch (Exception ex)
        {
            if (Chop.Web.Auth.AuthErrorRedirector.TryRedirect(ex, Session, NavigationManager))
            {
                return;
            }

            _error = Chop.Web.Auth.UiErrorMapper.ToUserMessage(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task EndShiftAsync(string guardUserId)
    {
        if (_busy)
        {
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            await Store.EndShiftAsync(guardUserId, CancellationToken.None);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            if (Chop.Web.Auth.AuthErrorRedirector.TryRedirect(ex, Session, NavigationManager))
            {
                return;
            }

            _error = Chop.Web.Auth.UiErrorMapper.ToUserMessage(ex);
        }
        finally
        {
            _busy = false;
        }
    }
}

