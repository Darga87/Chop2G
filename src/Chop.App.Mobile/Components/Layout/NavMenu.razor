@inject MobileSessionState Session
@inject NavigationManager Navigation
@implements IDisposable

<div class="flex items-center justify-between gap-2">
    <div class="text-sm font-semibold">Chop Mobile</div>
    <div class="flex items-center gap-2 text-xs">
        <NavLink class="tw-btn-outline" href="/login">Логин</NavLink>
        <NavLink class="tw-btn-outline" href="/sos">SOS</NavLink>
        @if (Session.IsAuthenticated)
        {
            <button class="tw-btn-danger" @onclick="SignOutAsync">Выход</button>
        }
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        Session.Changed += HandleChanged;
        await Session.EnsureInitializedAsync();
    }

    private async Task SignOutAsync()
    {
        await Session.SignOutAsync();
        Navigation.NavigateTo("/login", true);
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Session.Changed -= HandleChanged;
    }
}
