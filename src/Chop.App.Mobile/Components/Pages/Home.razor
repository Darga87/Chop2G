@page "/"
@inject MobileSessionState Session
@inject NavigationManager Navigation

<div class="tw-card">
    <div class="tw-card-body text-sm text-ink-700">Переход...</div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureInitializedAsync();
        Navigation.NavigateTo(Session.IsAuthenticated ? "/sos" : "/login", true);
    }
}
